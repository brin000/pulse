# Anthropic API key. Server-side only — it is never exposed to the browser.
# When this is missing (or PULSE_MOCK=1), Pulse runs in Mock mode:
# the full agent loop still works with deterministic decisions and canned data,
# which is useful for local development and demos.
ANTHROPIC_API_KEY=

# Force mock mode even when an API key is present (1 = on).
PULSE_MOCK=

# Force mock Reddit data instead of calling the public Reddit API (1 = on).
# Pulse also falls back to mock data automatically if the Reddit API is unreachable.
PULSE_MOCK_REDDIT=

# Force mock Hacker News data instead of calling the Algolia HN API (1 = on).
# Mirrors PULSE_MOCK_REDDIT; the HN adapter also falls back to mock data
# automatically if the API is unreachable. The HN API needs no credentials.
PULSE_MOCK_HN=

# Reddit OAuth script app (https://www.reddit.com/prefs/apps, type "script").
# Optional locally; required in production — anonymous Reddit API access is
# blocked from data-center IPs, so without these a deployment always falls
# back to mock data.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional gate for spending real LLM credits on a public deployment.
# When set, only visitors opening the page as /?live=<token> run in live mode;
# everyone else gets mock mode. Leave empty for local development.
PULSE_LIVE_TOKEN=

# Run-history database (libsql). Defaults to a local SQLite file under .data/
# (gitignored), so local development needs zero configuration. In production
# point it at a Turso database (libsql://...) and set the auth token.
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Secret protecting /api/cron/monitor. Vercel Cron sends it automatically as
# `Authorization: Bearer <CRON_SECRET>` when the env var is set on the project.
# Unset = the endpoint always returns 401 (fails closed).
CRON_SECRET=

# Optional email notifications for scheduled monitoring (Resend REST API).
# Both must be set for emails to go out; otherwise the cron logs one line and
# skips. NOTIFY_EMAIL is the recipient; the sender defaults to Resend's shared
# onboarding address (override with NOTIFY_FROM after verifying a domain).
RESEND_API_KEY=
NOTIFY_EMAIL=
