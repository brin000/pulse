# Anthropic API key. Server-side only — it is never exposed to the browser.
# When this is missing (or PULSE_MOCK=1), Pulse runs in Mock mode:
# the full agent loop still works with deterministic decisions and canned data,
# which is useful for local development and demos.
ANTHROPIC_API_KEY=

# Force mock mode even when an API key is present (1 = on).
PULSE_MOCK=

# Force mock Reddit data instead of calling the public Reddit API (1 = on).
# Pulse also falls back to mock data automatically if the Reddit API is unreachable.
PULSE_MOCK_REDDIT=

# Reddit OAuth script app (https://www.reddit.com/prefs/apps, type "script").
# Optional locally; required in production — anonymous Reddit API access is
# blocked from data-center IPs, so without these a deployment always falls
# back to mock data.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional gate for spending real LLM credits on a public deployment.
# When set, only visitors opening the page as /?live=<token> run in live mode;
# everyone else gets mock mode. Leave empty for local development.
PULSE_LIVE_TOKEN=
